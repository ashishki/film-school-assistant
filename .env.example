# Anthropic API key (used for Claude LLM calls)
LLM_API_KEY=sk-ant-...

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Numeric Telegram chat ID that the bot will accept messages from (single-user bot)
TELEGRAM_ALLOWED_CHAT_ID=your-authorized-chat-id

# Path to the SQLite database file (relative to repo root or absolute)
DB_PATH=data/assistant.db

# Directory where downloaded voice OGG files are stored temporarily
AUDIO_PATH=data/audio/

# Number of days to retain audio files before cleanup
AUDIO_RETENTION_DAYS=30

# Maximum number of LLM API calls allowed per day
DAILY_LLM_CALL_LIMIT=20

# Separate daily LLM budget for feature-request capture flow
FEATURE_CAPTURE_DAILY_LLM_LIMIT=12

# Maximum number of clarification questions when converting a missing feature into a short spec
FEATURE_CAPTURE_MAX_QUESTIONS=3

# Optional model overrides for feature-request capture
LLM_MODEL_FEATURE_CAPTURE=claude-haiku-4-5
LLM_MODEL_FEATURE_SPEC=claude-sonnet-4-6

# Reminder schedule: comma-separated days-before-deadline to send reminders
REMINDER_BUCKETS=7,3,1,0

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
